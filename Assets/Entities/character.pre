# A skinned, animated character: the Render component spawns the skinned mesh, the Animator component
# drives it with the CharacterAnimator graph. The fbx is large, so scale the whole entity down.
Prefab Character
	Component Render
		Scale 0.005
		SkinnedMesh CharacterMesh
	Component Animator
		Animator CharacterAnimator
	Component Script
		Path "Scripts/Character.scr"
	Component Audio
		Sound Bloop
			Path Sounds/bloop.wav
		Sound Blip
			Path Sounds/blip.wav
