# A dynamic rigid body cube (thrown from the camera with key 8 in the App testbed).
Prefab physicsCube
	Component Render
		ObjectContainer wireshapes
		Node Cube
	Component Physics
		Body Dynamic
		Shape Box
		HalfExtents 1.0, 1.0, 1.0
		Friction 0.6
		Restitution 0.1
	Component Audio
		Sound Blip
			Path Sounds/blip.wav
		Sound BlipLow
			Path Sounds/blip.wav
			Pitch 0.5
			Volume 0.8
