#include "ScriptAPI.h"
#include <cmath>

SCRIPT_EXPORT void ScriptUpdate(const ScriptContext* ctx, float dt)
{
    (void)dt;
    ctx->spawnPointLight(ScriptVec3{ 0.0f, 2.0f, 0.0f }, 25.0f, ScriptVec3{ 1.0f, 0.6f, 0.2f }, 60.0f);
}

