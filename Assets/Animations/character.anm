Animation idle
	ObjectContainer "Test/Anims/idle.fbx"
	Loop true
	Skip "Pose"

Animation walk
	ObjectContainer "Test/Anims/walk.fbx"
	Loop true
	Skip "Pose"
	Event footstep 0.25   # left foot
	Event footstep 0.75   # right foot

Animation run
	ObjectContainer "Test/Anims/run.fbx"
	Loop true
	Skip "Pose"
	Event footstep 0.5
	Event footstep 1.0

Animation attack
	ObjectContainer "Test/Anims/attack.fbx"
	Loop false
	Skip "Pose"
	Event hit 0.5
